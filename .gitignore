# Dependencias de Node (si usas npm para algo, ej. testing local)
node_modules/

# Archivos de sistema operativo
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini         # Windows

# Configuración de editor
.vscode/*
!.vscode/extensions.json
.idea/              # por si alguno usa WebStorm/IntelliJ

# Logs
*.log
npm-debug.log*

# Variables de entorno (por si en algún momento usan una API key o config sensible)
.env
.env.local

# Archivos temporales
*.tmp
*.bak
*.swp

# Carpeta de build (si en algún momento usan un bundler tipo Vite)
dist/
build/

# Archivos de cobertura de tests (si llegan a usar Jest u otro)
coverage/